# ── Groq (LLM inference) ─────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Langfuse (optional — observability tracing) ───────────────────────────────
# Get keys at: https://cloud.langfuse.com
# Leave as-is to disable tracing
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── UN Comtrade API (optional — legacy scripts only) ─────────────────────────
COMTRADE_PRIMARY_KEY=your_primary_key_here
COMTRADE_SECONDARY_KEY=your_secondary_key_here
